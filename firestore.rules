// firestore.rules
// ──────────────────────────────────────────────────────────────────
// Deploy with: firebase deploy --only firestore:rules
// ──────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requester is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check logged-in
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check own document
    function isOwn(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── users ────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwn(uid);                 // only self on registration
      allow update: if isOwn(uid) || isAdmin();    // self or admin
      allow delete: if isAdmin();
    }

    // ── passages ─────────────────────────────────────────────────
    match /passages/{passageId} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── sessions ─────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read:   if isAdmin() ||
                       (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if false;   // sessions are immutable
      allow delete: if isAdmin();
    }

    // ── leaderboard ──────────────────────────────────────────────
    match /leaderboard/{uid} {
      allow read:   if isAuth();
      allow write:  if isOwn(uid) || isAdmin();
    }
  }
}
